<header class="site-header">
  <div class="header-inner">
    <div class="header-left">
      <a href="/" class="logo"><%= salonName %></a>
    </div>

    <nav class="header-nav">
      <a href="/">Start</a>
      <a href="/services">Services</a>
      <a href="/portfolio">Portfolio</a>
      <a href="/termin">Termin</a>
      <a href="/produkte">Produkte</a>
      <a href="/team">Team</a>
    </nav>

    <div class="header-right">
      <div class="auth-links">
        <% if (user) { %>
          <% if (user.role === 'team') { %>
            <a href="/admin/profile" class="user-greeting text-link">💼 Hallo, <%= user.name %> (Team)</a>
          <% } else { %>
           <span class="user-greeting">Hallo, <%= user.name %></span>
          <% } %>
          <form action="/abmelden" method="post" class="inline-form">
            <button type="submit" class="link-btn">Abmelden</button>
          </form>
        <% } else { %>
          <a href="/anmelden">Anmelden</a>
          <a href="/registrieren">Registrieren</a>
        <% } %>
      </div>
      <a href="/warenkorb" class="cart-link">
  <i class="fa-solid fa-cart-shopping"></i> (<%= cartCount %>)
</a>
    </div>
  </div>
</header>
