<%- include('../partials/head') %>
<main class="container">
  <h1>Mein Team-Profil</h1>
  <% if (saved) { %><div class="alert alert-success">Profil gespeichert.</div><% } %>

  <form action="/team/profil/me" method="post" class="form-grid">
    <label>Name<input type="text" name="name" value="<%= member.name %>" required></label>
    <label>Rolle<input type="text" name="role" value="<%= member.role %>" required></label>
    <label>Bio<textarea name="bio" rows="4"><%= member.bio %></textarea></label>
    <fieldset>
      <legend>Meine Services</legend>
      <% services.forEach(function(s) { %>
        <label class="checkbox">
          <input type="checkbox" name="services" value="<%= s.id %>" <%= member.services.includes(s.id) ? 'checked' : '' %>>
          <%= s.name %>
        </label>
      <% }) %>
    </fieldset>
    <button type="submit" class="btn btn-primary">Profil speichern</button>
  </form>

  <section class="form-section">
    <h2>Meine Aufgaben</h2>
    <ul class="task-list">
      <% (member.tasks || []).forEach(function(task) { %>
        <li class="<%= task.done ? 'done' : '' %>">
          <span><%= task.title %></span>
          <form action="/team/profil/aufgabe/<%= task.id %>/toggle" method="post" class="inline-form">
            <button type="submit" class="btn btn-small"><%= task.done ? 'Offen' : 'Erledigt' %></button>
          </form>
          <form action="/team/profil/aufgabe/<%= task.id %>/loeschen" method="post" class="inline-form">
            <button type="submit" class="btn btn-small btn-danger">×</button>
          </form>
        </li>
      <% }) %>
    </ul>
    <form action="/team/profil/aufgabe" method="post" class="form-inline">
      <input type="text" name="title" placeholder="Neue Aufgabe" required>
      <button type="submit" class="btn btn-small">Hinzufügen</button>
    </form>
  </section>
</main>
<%- include('../partials/foot') %>
