<%- include('../partials/head') %>
<main class="container">


  <h1>Services & Preise</h1>

    <table class="data-table">
    <thead>
      <tr>
        <th>Service</th>
        <th>Beschreibung</th>
        <th>Dauer (Min.)</th>
        <th>Preis</th>
      </tr>
    </thead>
    <tbody>
      <% services.forEach(function(s) { %>
        <tr>
          <td><%= s.name %></td>
          <td><%= s.description %></td>
          <td><%= s.duration %></td>
          <td><%= (s.price ? Number(s.price).toFixed(2) : '0.00') %> €</td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <p><a href="/termin" class="btn btn-primary">Termin buchen</a></p>
</main>
<%- include('../partials/foot') %>
