<%- include('../partials/head') %>


<main class="container product-detail-page">
 
  <h1><%= product.name %></h1>
  <!-- Produktbild -->
  <img src="<%= product.image %>" alt="<%= product.name %>" class="product-detail-image">
  <!-- Beschreibung -->
  <p><%= product.description %></p>
  <!-- Preis + Lager -->
  <p class="price">Preis: <%= product.price.toFixed(2) %> €</p>
  <p class="stock">Lagerbestand: <%= product.stock %></p>

  <!-- Mengensteuerung -->
<div class="quantity-control">
  <p class="menge-label">Menge:
  <button id="minus" class="qty-btn">-</button>
  <span id="count">1</span>
  <button id="plus" class="qty-btn">+</button>
  </p>
</div>

  <!-- In den Warenkorb -->
  <form action="/produkte/<%= product.id %>/warenkorb" method="post">
    <input type="hidden" name="quantity" id="quantityInput" value="1">
    <button type="submit" class="btn btn-primary" <%= product.stock <= 0 ? 'disabled' : '' %>>
      In den Warenkorb
    </button>
  </form>
</main>

<script>
  let count = 1;
  const countEl = document.getElementById("count");
  const quantityInput = document.getElementById("quantityInput");
   const minusBtn = document.getElementById("minus");
  const plusBtn = document.getElementById("plus");

   // Startzustand: minus deaktiviert
  minusBtn.disabled = true;

 plusBtn.addEventListener("click", () => {
    count++;
    countEl.textContent = count;
    quantityInput.value = count;

    if (count > 1) {
      minusBtn.disabled = false;
    }
  });

  minusBtn.addEventListener("click", () => {
    if (count > 1) {
      count--;
      countEl.textContent = count;
      quantityInput.value = count;
    }

    if (count === 1) {
      minusBtn.disabled = true;
    }
  }); 

</script>

<%- include('../partials/foot') %>
