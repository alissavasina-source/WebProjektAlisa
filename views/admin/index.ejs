<%- include('../partials/header') %>

<main class="admin-page">

    <h1>Admin Bereich</h1>

    <p>Hier können später Inhalte der Webseite geändert oder hinzugefügt werden.</p>

    <div class="admin-card">
        <h2>Portfolio-Bilder</h2>
        <form action="/admin/portfolio" method="POST" enctype="multipart/form-data">
            <input type="file" name="portfolioImage">
            <button class="admin-btn" type="submit">Hochladen</button>
        </form>
    </div>

    <div class="admin-card">
        <h2>Teammitglieder</h2>
        <form action="/admin/team" method="POST" enctype="multipart/form-data">
            <input type="text" name="name" placeholder="Name">
            <input type="text" name="job" placeholder="Spezialisierung">
            <input type="file" name="teamImage">
            <button class="admin-btn" type="submit">Speichern</button>
        </form>
    </div>

    <div class="admin-card">
        <h2>Produkte</h2>
        <form action="/admin/products" method="POST">
            <input type="text" name="name" placeholder="Produktname">
            <input type="number" name="price" placeholder="Preis">
            <button class="admin-btn" type="submit">Speichern</button>
        </form>
    </div>

    <div class="admin-card">
        <h2>Dienstleistungen und Preise</h2>
        <form action="/admin/services" method="POST">
            <input type="text" name="name" placeholder="Dienstleistung">
            <input type="number" name="price" placeholder="Preis">
            <button class="admin-btn" type="submit">Speichern</button>
        </form>
    </div>

    <div class="admin-card">
        <h2>Termine</h2>
        <form action="/admin/termine" method="POST">
            <input type="date" name="date">
            <input type="time" name="time">
            <button class="admin-btn" type="submit">Speichern</button>
        </form>
    </div>

</main>

<%- include('../partials/footer') %>