<%- include('../partials/head') %>
<main class="container admin-page">
  <%- include('../partials/adminMenu') %>
  <div class="admin-container">
  <h1>Administration Services</h1>

  

    <section class="form-section">
      <h2>Services bearbeiten</h2>
      <% services.forEach(function(s) { %>
        <div class="edit-row">
          <form action="/admin/services/<%= s.id %>/bearbeiten" method="post" class="form-grid inline-edit">
            <input type="text" name="name" value="<%= s.name %>" required>
            <input type="text" name="description" value="<%= s.description %>" required>
            <input type="number" name="duration" value="<%= s.duration %>" min="1" required>
            <input type="number" name="price" value="<%= s.price %>" step="0.01" min="0" required>
            <button type="submit" class="btn btn-small">Speichern</button>
          </form>
          <form action="/admin/services/<%= s.id %>/loeschen" method="post" class="inline-form">
            <button type="submit" class="btn btn-small btn-danger">Löschen</button>
          </form>
        </div>
      <% }) %>

      <h3>Neuen Service hinzufügen</h3>
      <form action="/admin/services/neu/" method="post" class="form-grid">
        <label>Name<input type="text" name="name" required></label>
        <label>Beschreibung<input type="text" name="description" required></label>
        <label>Dauer (Min.)<input type="number" name="duration" min="1" required></label>
        <label>Preis (€)<input type="number" name="price" step="0.01" min="0" required></label>
        <button type="submit" class="btn btn-primary">Hinzufügen</button>
      </form>
    </section>
</div>
</main>
<%- include('../partials/foot') %>