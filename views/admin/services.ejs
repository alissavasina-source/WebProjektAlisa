<%- include('../partials/head') %>
<main class="container admin-page">
  <%- include('../partials/adminMenu') %>
  <div class="admin-container">
  <h1>Administration Services</h1>

  

    <section class="form-section">
      <h2>Services bearbeiten</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Service</th>
            <th>Beschreibung</th>
            <th>Dauer/in min</th>
            <th>Preis</th>
            <th colspan="2">Aktionen</th>
          </tr>
        </thead>
        <tbody>
          <% if (services.length === 0) { %>
            <tr><td colspan="5">Keine Services vorhanden.</td></tr>
          <% } %>
          <% services.forEach(function(s) { %>
           <tr>
            <td><strong><%= s.name %></strong></td>
            <td><%= s.description %></td>
            <td><%= s.duration %> Min.</td>
            <td><%= (s.price ? Number(s.price).toFixed(2) : '0.00') %> €</td>
            <td>
              <div style="display: flex; gap: 10px;">
                <button type="button" class="btn btn-small" onclick="document.getElementById('edit-modal-<%= s.id %>').style.display='block'">Bearbeiten</button>
                
                <form action="/admin/services/<%= s.id %>/loeschen" method="post" style="margin:0;" onsubmit="return confirm('Möchtest du diesen Service wirklich löschen?');">
                  <button type="submit" class="btn btn-small btn-danger">Löschen</button>
                </form>
              </div>

              <div id="edit-modal-<%= s.id %>" style="display:none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5);">
                <div style="background-color: white; margin: 10% auto; padding: 20px; border-radius: 8px; width: 400px; box-shadow: 0 4px 8px rgba(0,0,0,0.2);">
                  <h3>Service bearbeiten</h3>
                  
                  <form action="/admin/services/<%= s.id %>/bearbeiten" method="post" style="display: flex; flex-direction: column; gap: 15px;">
                    <label>Name:
                      <input type="text" name="name" value="<%= s.name %>" style="width:100%; padding:8px;" required>
                    </label>
                    <label>Beschreibung:
                      <input type="text" name="description" value="<%= s.description %>" style="width:100%; padding:8px;" required>
                    </label>
                    <label>Dauer (Min.):
                      <input type="number" name="duration" value="<%= s.duration %>" min="1" style="width:100%; padding:8px;" required>
                    </label>
                    <label>Preis (€):
                      <input type="number" name="price" value="<%= s.price %>" step="0.01" min="0" style="width:100%; padding:8px;" required>
                    </label>
                    
                    <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 10px;">
                      <button type="button" class="btn" style="background:#ccc;" onclick="document.getElementById('edit-modal-<%= s.id %>').style.display='none'">Abbrechen</button>
                      <button type="submit" class="btn btn-primary">Änderungen speichern</button>
                    </div>
                  </form>
                </div>
              </div>

            </td>
          </tr>
            <% }) %>  
        </tbody>
      </table>
      

      <h3>Neuen Service hinzufügen</h3>
      <form action="/admin/services/neu/" method="post" class="form-grid">
        <label>Name<input type="text" name="name" required></label>
        <label>Beschreibung<input type="text" name="description" required></label>
        <label>Dauer (Min.)<input type="number" name="duration" min="1" required></label>
        <label>Preis (€)<input type="number" name="price" step="0.01" min="0" required></label>
        <button type="submit" class="btn btn-primary">Hinzufügen</button>
      </form>
    </section>
</div>
</main>
<%- include('../partials/footer') %>