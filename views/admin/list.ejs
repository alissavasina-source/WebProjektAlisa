<%- include('../partials/head') %>
<main class="container admin-page">
  <%- include('../partials/adminMenu') %>
  <div class="admin-container">
  <h1>Terminübersicht</h1>

  <table class="data-table">
    <thead>
      <tr>
        <th>Datum</th>
        <th>Uhrzeit</th>
        <th>Service</th>
        <th>Teammitglied</th>
        <th>Kunde</th>
        <th>Kontakt</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if (appointments.length === 0) { %>
        <tr><td colspan="6">Keine Termine vorhanden.</td></tr>
      <% } %>
      <% appointments.forEach(function(a) { %>
        <tr>
          <td><%= a.date %></td>
          <td><%= a.time %></td>
          <td><%= a.serviceName %></td>
          <td><%= a.teamMemberName %></td>
          <td><%= a.customerName %></td>
          <td><%= a.customerEmail %><% if (a.customerPhone) { %><br><%= a.customerPhone %><% } %></td>
          <td>
            <form action="/admin/termin/stornieren/<%= a.id %>" method="post" style="display:inline;">
            <button type="submit" class="btn btn-primary btn-danger">Stornieren</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
</main>
<%- include('../partials/foot') %>
